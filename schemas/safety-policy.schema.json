{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plywood.local/schemas/safety-policy.schema.json",
  "title": "Plywood Safety Policy",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "name",
    "version",
    "default_result",
    "rules"
  ],
  "properties": {
    "schema_version": {
      "const": "plywood.safety_policy.v1"
    },
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "default_result": {
      "enum": [
        "safe",
        "needs_approval",
        "blocked"
      ]
    },
    "default_reason": {
      "type": "string"
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "result",
          "match",
          "reason"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "result": {
            "enum": [
              "safe",
              "needs_approval",
              "blocked"
            ]
          },
          "match": {
            "type": "object"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    }
  }
}
